# Copy to scripts/.env and fill in. scripts/.env is git-ignored.

# Network: testnet | mainnet | devnet | localnet
SUI_NETWORK=testnet
# Optional: override the RPC URL (defaults to the public fullnode for SUI_NETWORK)
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Seeder / keeper signer. Export with `sui keytool export --key-identity <addr>`
# and paste the suiprivkey1... value here.
SUI_PRIVATE_KEY=suiprivkey1...

# DeepBook quote coin key (testnet default is DeepBook's test USDC).
QUOTE_COIN_KEY=DBUSDC

# --- deepbook:mint (mint PT/YT inventory for the seeder) ---
# Raw base units of the underlying to split into PT+YT.
MINT_AMOUNT_BASE=1000000000

# --- deepbook:seed (deposit sizes, human units) ---
SEED_PT=500
SEED_YT=500
SEED_QUOTE=500
SEED_ORDER_SIZE=100
SEED_PAY_WITH_DEEP=false
# Optional maker price overrides:
# PT_BID_1=0.95
# PT_BID_2=0.96
# PT_ASK_1=0.97
# PT_ASK_2=0.98
# YT_BID_1=0.03
# YT_BID_2=0.035
# YT_ASK_1=0.045
# YT_ASK_2=0.05

# --- walrus keeper ---
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5
# Keeper cadence in seconds and how many points to keep in the rolling series.
KEEPER_INTERVAL_SECONDS=300
KEEPER_MAX_POINTS=500
# Optional: nominal APY proxy for the accrual index when no real source is wired.
ACCRUAL_APY=0.06
